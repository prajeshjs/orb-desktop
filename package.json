{
  "name": "smart-task-tracker",
  "version": "1.0.0",
  "description": "Orb - Smart Task Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "Your Name",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.orb.app",
    "productName": "Orb",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist",
      "!.env",
      "!website"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Orb",
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "groq-sdk": "^0.37.0",
    "sqlite3": "^5.1.7"
  }
}